# Copy this to .env and fill in your values.

# PostgreSQL connection string
# DATABASE_URL=postgres://user:password@localhost:5432/appointments

# Sqlite connection string
DATABASE_URL=sqlite:./db.sqlite

# Firebase project ID (found in your Firebase console under Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Port to listen on (optional, defaults to 3000)
PORT=3000

# Tracing level (optional)
RUST_LOG=appointment_backend=debug,tower_http=debug
